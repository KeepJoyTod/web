# Local development defaults. Do not reuse these credentials in production.
MODE=dev

# MySQL (shared by Docker Compose, deployment scripts, and Spring Boot)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=web
DB_USER=root
DB_PASSWORD=123456

# Optional when multiple clones with the same directory name share one Docker daemon.
# Use a unique value in each clone, for example: projectku-web-alice
# COMPOSE_PROJECT_NAME=projectku-web-alice

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0

# Application ports
BACKEND_PORT=8080
FRONTEND_PORT=5173
ADMIN_PORT=5174
