{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:login": "playwright test tests/login.spec.ts",
    "test:register": "playwright test tests/register.spec.ts",
    "test:navigation": "playwright test tests/navigation.spec.ts",
    "test:product-detail": "playwright test tests/product-detail.spec.ts",
    "test:cart": "playwright test tests/cart.spec.ts",
    "test:checkout": "playwright test tests/checkout.spec.ts",
    "allure:generate": "set ALLURE_NO_ANALYTICS=1&& allure generate allure-results --clean -o allure-report",
    "allure:open": "set ALLURE_NO_ANALYTICS=1&& allure open allure-report",
    "allure:serve": "set ALLURE_NO_ANALYTICS=1&& allure serve allure-results"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vue-tsc": "^3.2.5"
  }
}
